import { NextRequest, NextResponse } from 'next/server'

// Metadata for better offline tracking
interface OrderMetadata {
  id: string
  orderNumber: string
  tableNumber?: number
  customerName?: string
  items: Array<{ _id: string; name: string; price: number; quantity: number }>
  subtotal: number
  tax: number
  discount: number
  total: number
  status: 'pending' | 'confirmed' | 'preparing' | 'ready' | 'completed'
  createdAt: string
}

export async function GET(req: NextRequest) {
  try {
    // Get all orders from browser localStorage metadata
    // In a real application, this would come from cookies or headers
    // For now, return empty array since we're using client-side localStorage
    return NextResponse.json({ orders: [] })
  } catch (error) {
    console.error('Get orders error:', error)
    return NextResponse.json({ orders: [] })
  }
}

export async function POST(req: NextRequest) {
  try {
    const {
      items,
      subtotal,
      discount,
      tax,
      total,
      paymentMethod,
      customerName,
      tableNumber,
      status,
      autoprint,
    } = await req.json()

    // Generate order number
    const orderNumber = Math.floor(1000 + Math.random() * 9000)
    const orderId = `order-${Date.now()}-${Math.random()}`

    const order: OrderMetadata = {
      id: orderId,
      orderNumber: orderNumber.toString(),
      customerName: customerName || undefined,
      tableNumber: tableNumber || undefined,
      items: items.map((item: any) => ({
        _id: item._id || `item-${Date.now()}`,
        name: item.itemName || item.name,
        price: item.price || 0,
        quantity: item.quantity || item.qty || 0,
      })),
      subtotal: Number(subtotal) || 0,
      discount: Number(discount) || 0,
      tax: Number(tax) || 0,
      total: Number(total) || 0,
      status: status || 'pending',
      createdAt: new Date().toISOString(),
    }

    // Return order - client will handle localStorage storage via localOrderManager
    return NextResponse.json(
      {
        order,
        autoprint: autoprint || false,
      },
      { status: 201 }
    )
  } catch (error) {
    console.error('Create order error:', error)
    return NextResponse.json(
      { message: 'Failed to create order' },
      { status: 500 }
    )
  }
}

export async function PATCH(req: NextRequest) {
  try {
    const { status } = await req.json()

    // Return success - client handles localStorage update
    return NextResponse.json({
      order: { status },
      message: 'Order updated (handled client-side)',
    })
  } catch (error) {
    console.error('Update order error:', error)
    return NextResponse.json(
      { message: 'Failed to update order' },
      { status: 500 }
    )
  }
}

export async function DELETE(req: NextRequest) {
  try {
    // Client handles deletion from localStorage
    return NextResponse.json({
      message: 'Order deleted (handled client-side)',
    })
  } catch (error) {
    console.error('Delete order error:', error)
    return NextResponse.json(
      { message: 'Failed to delete order' },
      { status: 500 }
    )
  }

export async function PATCH(req: NextRequest, { params }: { params: { id: string } }) {
  try {
    const { status } = await req.json()
    const client = await getMongoClient()
    const db = client.db('restaurant_pro')

    const result = await db.collection('orders').findOneAndUpdate(
      { _id: new ObjectId(params.id) },
      { $set: { status, updatedAt: new Date() } },
      { returnDocument: 'after' }
    )

    const order = result?.value || null
    const normalized = order ? {
      ...order,
      _id: order._id.toString(),
      createdAt: order.createdAt?.toISOString(),
      updatedAt: order.updatedAt?.toISOString(),
    } : null
    return NextResponse.json({ order: normalized })
  } catch (error) {
    console.error('Update order error:', error)
    return NextResponse.json({ message: 'Failed to update order' }, { status: 500 })
  }
}

export async function DELETE(req: NextRequest, { params }: { params: { id: string } }) {
  try {
    const client = await getMongoClient()
    const db = client.db('restaurant_pro')
    await db.collection('orders').deleteOne({ _id: new ObjectId(params.id) })
    return NextResponse.json({ success: true })
  } catch (error) {
    console.error('Delete order error:', error)
    return NextResponse.json({ message: 'Failed to delete order' }, { status: 500 })
  }
}
